<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="eBuddy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:eBuddy"
    Title="eBuddy"
    FlyoutBehavior="Flyout">

    <!-- Service book page -->
    <FlyoutItem Title="{x:Static local:AppResources.ServiceBookTitle}" Icon="book_icon.png">
        <ShellContent
            Title="{x:Static local:AppResources.ServiceBookTitle}"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

