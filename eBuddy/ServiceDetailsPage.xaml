<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:eBuddy"
             x:Class="eBuddy.ServiceDetailsPage"
             Title="{x:Static local:AppResources.ServiceDetailsPageTitle}">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">
            <Label x:Name="TitleLabel" FontSize="24"/>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{x:Static local:AppResources.ServiceDateLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <Label x:Name="DateLabel" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{x:Static local:AppResources.ServiceMileageLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <Label x:Name="MileageLabel" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{x:Static local:AppResources.ServiceTypeLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <Label x:Name="TypeLabel" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{x:Static local:AppResources.ServiceDescriptionLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <Label x:Name="DescriptionLabel" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{x:Static local:AppResources.ServiceCostLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <Label x:Name="CostLabel" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{x:Static local:AppResources.ServicedByLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <Label x:Name="ServicedByLabel" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label Text="{x:Static local:AppResources.FilesAttachedLabel}" FontSize="14" TextColor="{StaticResource ThemeTextSecondary}"/>
                    <ListView x:Name="filesListView" HasUnevenRows="True" ItemSelected="OnFileSelected">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextCell Text="{Binding FileName}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </VerticalStackLayout>
            </Border>

            <Button Text="{x:Static local:AppResources.EditServiceButton}" Clicked="OnEditClicked"/>
            <Button Text="{x:Static local:AppResources.DeleteServiceButton}" Clicked="OnDeleteClicked" TextColor="{StaticResource ThemeWarning}"
                    ImageSource="trash_icon.png"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>